---
import { eq } from 'drizzle-orm'
import Layout from '~/client/layouts/Layout.astro'
import { db } from '~/server/database/client'
import { articlesTable } from '~/server/database/schema'
import { renderMarkdown } from '~/server/utils/markdown/renderMarkdown'
import ArticleView from '~/client/components/news/ArticleView.vue'
import IndexHeader from '~/client/components/common/IndexHeader.vue'

const { uuid } = Astro.params

if (!uuid) {
  return Astro.redirect('/')
}

const [article] = await db
  .select()
  .from(articlesTable)
  .where(eq(articlesTable.id, uuid))
  .limit(1)

if (!article) {
  return Astro.redirect('/404')
}

const html = await renderMarkdown(article.content)
---

<Layout title={article.title}>
  <IndexHeader slot="header" />
  <!-- <article slot="main" class="markdown-body" set:html={html} /> -->
  <ArticleView client:only="vue" html={html} uuid={uuid} slot="main" />
</Layout>
