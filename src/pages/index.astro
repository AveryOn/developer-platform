---
import Layout from '~/client/layouts/Layout.astro'
---

<Layout
  title={locals.title}
  favicons={locals.favicons}
  description={locals.description}
  product={locals.provider}
>
  <FormSignIn
    product={locals.provider}
    client:only="vue"
    isDangerMode={isDangerMode}
    traceId={traceId}
    isMobile={false}
  />

  <TermsOfUseFooter slot="footer-after" client:only="vue" />
</Layout>
